# MongoDB connection string
# For local dev: mongodb://localhost:27017/chicago-plant-plan
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/chicago-plant-plan
MONGODB_URI=mongodb://localhost:27017/chicago-plant-plan

# --- Auth (Google OAuth + JWT sessions) ---
# Base URL where this app runs, used to derive the OAuth redirect_uri.
# Must exactly match the authorized redirect URI in your Google Cloud OAuth client:
#   {NEXTAUTH_URL}/api/auth/google/callback
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 credentials (Google Cloud Console → APIs & Services → Credentials → OAuth client ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 32+ byte random string used to sign session JWTs and OAuth state tokens.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Comma-separated list of emails that should become admins on first sign-in.
# Example: AUTH_ADMIN_EMAILS=you@example.com,teammate@example.com
AUTH_ADMIN_EMAILS=
